// TruVis.info — Prisma Schema
// PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  company
  admin
  super_admin
}

enum CompanyStatus {
  draft
  pending
  approved
  rejected
}

enum ServiceType {
  service
  product
  capability
}

enum BlogStatus {
  draft
  pending
  published
  rejected
}

enum EmployeeCount {
  one_to_ten       @map("1-10")
  eleven_to_fifty  @map("11-50")
  fifty_to_two     @map("51-200")
  two_to_five      @map("201-500")
  five_plus        @map("500+")
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  past_due
}

enum BillingCycle {
  monthly
  annually
}

enum MarketplaceListingType {
  business_for_sale
  investment
  partnership
}

enum MarketplaceListingStatus {
  draft
  active
  under_offer
  sold
  withdrawn
}

enum NdaStatus {
  pending
  approved
  rejected
}

enum InquiryStatus {
  unread
  read
  replied
}

// ─────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  role           UserRole  @default(company)
  emailVerified  Boolean   @default(false) @map("email_verified")
  emailToken     String?   @map("email_token")
  emailTokenExp  DateTime? @map("email_token_exp")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company          Company?
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  approvedCompanies Company[]     @relation("ApprovedBy")
  verifiedCompanies Company[]     @relation("VerifiedBy")
  assignedTags     CompanyServiceTag[]
  authoredPosts    BlogPost[]
  marketplaceListings MarketplaceListingItem[]
  ndaRequests      NdaRequest[]

  @@map("users")
}

model Company {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  slug             String        @unique
  name             String
  licenseNumber    String?       @map("license_number")
  description      String?       @db.Text
  tagline          String?
  foundedYear      Int?          @map("founded_year")
  employeeCount    EmployeeCount? @map("employee_count")
  website          String?
  email            String?
  phone            String?
  whatsapp         String?
  address          String?       @db.Text
  city             String?
  country          String?
  latitude         Decimal?      @db.Decimal(10, 8)
  longitude        Decimal?      @db.Decimal(11, 8)
  logoUrl          String?       @map("logo_url")
  coverUrl         String?       @map("cover_url")
  videoUrl         String?       @map("video_url")
  gallery          Json          @default("[]")
  socialLinks      Json          @default("{}") @map("social_links")
  status           CompanyStatus @default(draft)
  rejectionReason  String?       @map("rejection_reason") @db.Text
  profileScore     Int           @default(0) @map("profile_score")
  featured         Boolean       @default(false)
  featuredUntil    DateTime?     @map("featured_until")
  featuredOrder    Int           @default(0) @map("featured_order")
  truvisClient     Boolean       @default(false) @map("truvis_client")
  truvisVerified   Boolean       @default(false) @map("truvis_verified")
  verifiedAt       DateTime?     @map("verified_at")
  verifiedById     String?       @map("verified_by")
  approvedAt       DateTime?     @map("approved_at")
  approvedById     String?       @map("approved_by")
  viewsCount       Int           @default(0) @map("views_count")
  contactCount     Int           @default(0) @map("contact_count")
  lastActivityAt   DateTime      @default(now()) @map("last_activity_at")
  rankScore        Decimal       @default(0) @db.Decimal(10, 4) @map("rank_score")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy       User?         @relation("VerifiedBy", fields: [verifiedById], references: [id])
  approvedBy       User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  industries       CompanyIndustry[]
  categories       CompanyCategory[]
  serviceTags      CompanyServiceTag[]
  services         Service[]
  blogPosts        BlogPost[]
  inquiries        ContactInquiry[]
  subscription     CompanySubscription?
  marketplaceListing MarketplaceListingItem?

  @@index([status, rankScore(sort: Desc)])
  @@index([country, city])
  @@index([truvisVerified, featured])
  @@map("companies")
}

model Industry {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  categories  Category[]
  companies   CompanyIndustry[]
  marketplaceListings MarketplaceListingItem[]

  @@map("industries")
}

model Category {
  id          String   @id @default(uuid())
  industryId  String   @map("industry_id")
  name        String
  slug        String   @unique
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  industry    Industry @relation(fields: [industryId], references: [id])
  companies   CompanyCategory[]

  @@map("categories")
}

model CompanyIndustry {
  companyId   String  @map("company_id")
  industryId  String  @map("industry_id")
  isPrimary   Boolean @default(false) @map("is_primary")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industry    Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([companyId, industryId])
  @@map("company_industries")
}

model CompanyCategory {
  companyId   String  @map("company_id")
  categoryId  String  @map("category_id")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([companyId, categoryId])
  @@map("company_categories")
}

model TruvisServiceTag {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")

  companies   CompanyServiceTag[]

  @@map("truvis_service_tags")
}

model CompanyServiceTag {
  companyId   String   @map("company_id")
  tagId       String   @map("tag_id")
  assignedById String? @map("assigned_by")
  assignedAt  DateTime @default(now()) @map("assigned_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag         TruvisServiceTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedBy  User?            @relation(fields: [assignedById], references: [id])

  @@id([companyId, tagId])
  @@map("company_service_tags")
}

model Service {
  id          String      @id @default(uuid())
  companyId   String      @map("company_id")
  type        ServiceType @default(service)
  title       String
  description String?     @db.Text
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("services")
}

model BlogPost {
  id               String     @id @default(uuid())
  companyId        String     @map("company_id")
  authorId         String     @map("author_id")
  title            String
  slug             String     @unique
  content          String     @db.Text
  excerpt          String?
  coverUrl         String?    @map("cover_url")
  status           BlogStatus @default(draft)
  rejectionReason  String?    @map("rejection_reason") @db.Text
  publishedAt      DateTime?  @map("published_at")
  viewsCount       Int        @default(0) @map("views_count")
  metaTitle        String?    @map("meta_title")
  metaDescription  String?    @map("meta_description")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author      User    @relation(fields: [authorId], references: [id])

  @@index([status, publishedAt(sort: Desc)])
  @@map("blog_posts")
}

model ContactInquiry {
  id           String        @id @default(uuid())
  companyId    String?       @map("company_id")
  senderName   String        @map("sender_name")
  senderEmail  String        @map("sender_email")
  senderPhone  String?       @map("sender_phone")
  subject      String?
  message      String        @db.Text
  ipAddress    String?       @map("ip_address")
  status       InquiryStatus @default(unread)
  createdAt    DateTime      @default(now()) @map("created_at")

  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("contact_inquiries")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tokenHash   String   @unique @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  revoked     Boolean  @default(false)
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// MONETIZATION
// ─────────────────────────────────────────

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?  @db.Text
  priceMonthly   Decimal? @map("price_monthly") @db.Decimal(10, 2)
  priceAnnually  Decimal? @map("price_annually") @db.Decimal(10, 2)
  currency       String   @default("USD")
  features       Json     @default("{}")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  subscriptions  CompanySubscription[]

  @@map("subscription_plans")
}

model CompanySubscription {
  id           String             @id @default(uuid())
  companyId    String             @unique @map("company_id")
  planId       String             @map("plan_id")
  status       SubscriptionStatus @default(active)
  billingCycle BillingCycle       @map("billing_cycle")
  startedAt    DateTime           @default(now()) @map("started_at")
  expiresAt    DateTime?          @map("expires_at")
  cancelledAt  DateTime?          @map("cancelled_at")
  paymentRef   String?            @map("payment_ref")
  createdAt    DateTime           @default(now()) @map("created_at")

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("company_subscriptions")
}

// ─────────────────────────────────────────
// MARKETPLACE (FUTURE-READY)
// ─────────────────────────────────────────

model MarketplaceListingItem {
  id             String                   @id @default(uuid())
  companyId      String?                  @unique @map("company_id")
  listedById     String                   @map("listed_by")
  type           MarketplaceListingType
  title          String
  description    String?                  @db.Text
  askingPrice    Decimal?                 @map("asking_price") @db.Decimal(15, 2)
  currency       String                   @default("USD")
  revenueAnnual  Decimal?                 @map("revenue_annual") @db.Decimal(15, 2)
  ebitda         Decimal?                 @db.Decimal(15, 2)
  industryId     String?                  @map("industry_id")
  country        String?
  city           String?
  isConfidential Boolean                  @default(true) @map("is_confidential")
  ndaRequired    Boolean                  @default(true) @map("nda_required")
  status         MarketplaceListingStatus @default(draft)
  viewsCount     Int                      @default(0) @map("views_count")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  expiresAt      DateTime?                @map("expires_at")

  company        Company?  @relation(fields: [companyId], references: [id])
  listedBy       User      @relation(fields: [listedById], references: [id])
  industry       Industry? @relation(fields: [industryId], references: [id])
  ndaRequests    NdaRequest[]

  @@map("marketplace_listings")
}

model NdaRequest {
  id           String    @id @default(uuid())
  listingId    String    @map("listing_id")
  requesterId  String    @map("requester_id")
  fullName     String    @map("full_name")
  companyName  String?   @map("company_name")
  email        String
  phone        String?
  purpose      String?   @db.Text
  status       NdaStatus @default(pending)
  signedAt     DateTime? @map("signed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  listing      MarketplaceListingItem @relation(fields: [listingId], references: [id])
  requester    User                   @relation(fields: [requesterId], references: [id])

  @@map("nda_requests")
}
