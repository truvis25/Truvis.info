    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "isomorphic-dompurify": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "resend": "^3.2.0",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
