# Truvis.info environment variables.
# Copy to .env.local and fill in per environment. Every var here is optional
# for local dev unless noted — the app boots against the live Supabase project
# using the public defaults baked into lib/config.ts.

# --- Supabase (public values have safe built-in defaults in lib/config.ts) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # secret; required for webhooks, crons, email recipient lookup, and the seed script
NEXT_PUBLIC_SITE_URL=             # e.g. http://localhost:3000 (defaults to https://truvis.info)

# --- Compliance partner API ---
COMPLIANCE_API_MODE=mock          # "mock" = built-in catalog; anything else = real HTTP client
COMPLIANCE_API_BASE_URL=          # required when not mock
COMPLIANCE_API_KEY=               # required when not mock
COMPLIANCE_WEBHOOK_SECRET=        # HMAC secret for /api/webhooks/compliance

# --- Cron auth (Vercel schedules) ---
CRON_SECRET=                      # optional bearer check on /api/cron/* routes

# --- Luma (community calendar sync) ---
LUMA_API_MODE=mock                # "mock" = no external calls
LUMA_API_BASE_URL=
LUMA_API_KEY=

# --- Email (Phase 1) — unset SMTP_HOST means emails are skipped with a console warning ---
SMTP_HOST=
SMTP_PORT=587                     # 465 = implicit TLS, anything else = STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Truvis.info <no-reply@truvis.info>"

# --- Stripe (Phase 2) — unset STRIPE_SECRET_KEY means billing is dormant and the trial flow stays active ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=            # from the Stripe dashboard webhook endpoint

# --- E2E (Phase 4) ---
CHROMIUM_PATH=                    # sandbox-only override for Playwright's chromium binary

# --- Monitoring (Phase 4, future) ---
SENTRY_DSN=                       # when set, wire into instrumentation.ts onRequestError
