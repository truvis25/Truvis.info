# ─────────────────────────────────────────
# TruVis.info — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# ── Application ─────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database ────────────────────────────
DATABASE_URL=postgresql://truvis:password@localhost:5432/truvis_dev
POSTGRES_DB=truvis_dev
POSTGRES_USER=truvis
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ───────────────────────────────
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=change_me_in_production

# ── JWT (RS256) ─────────────────────────
# For development, JWT_SECRET is used (HS256)
# For production, generate RS256 keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_SECRET=dev-only-change-in-production-min-32-chars
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Cloudflare R2 Storage ───────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=truvis-media
R2_PUBLIC_URL=https://media.truvis.info

# ── Email (Resend) ──────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@truvis.info
ADMIN_EMAIL=admin@truvis.info

# ── Security ────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret
CORS_ORIGINS=http://localhost:3000
BCRYPT_ROUNDS=12

# ── Monitoring ──────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=info

# ── Frontend (Next.js public vars) ──────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
